---
layout: base.njk
title: "Richard Feynman"
description: "Physicist, Nobel laureate, bongo drummer. I was born not knowing and have had only a little time to change that here and there."
permalink: /editor-feynman/
---

{# === TOP PANEL === #}
<div class="announcement-slider">
    <div class="tier2-hero tier2-hero-feynman">
        <img src="/images/hero-feynman.png" alt="Double slit experiment" class="slider-img">
        <span class="mosaic-badge mosaic-badge-feynman">INTERBEING</span>
        <div class="slider-overlay">
            <div class="tier2-overview-player" data-audio="/audio/feynman-overview.mp3">
                <button class="tier2-overview-play" aria-label="Play overview">&#9654;</button>
                <audio preload="metadata" src="/audio/feynman-overview.mp3"></audio>
            </div>
            <h1 class="slider-title" style="font-size: 1.6em;">Richard Feynman</h1>
            <p class="slider-desc">Physicist, Nobel laureate, bongo drummer</p>
            <p class="slider-desc" style="opacity: 0.7; font-style: italic;">I was born not knowing and have had only a little time to change that here and there.</p>
        </div>
    </div>
</div>

{# === MOSAIC GRID === #}
<section class="mosaic-section">
    <div class="mosaic-grid">
        {% set feynmanPosts = collections.feynman | reverse %}
        {% for post in feynmanPosts %}
        <a href="{{ post.url }}" class="mosaic-card mosaic-feynman"
           {% if post.data.audio %}data-audio="{{ post.data.audio }}"{% endif %}
           {% if loop.index > 12 %}style="display:none;" data-lazy="true"{% endif %}>
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">
            {% endif %}
            <span class="mosaic-badge mosaic-badge-feynman">{% if post.data.audio %}AUDIO{% else %}TEXT{% endif %}</span>
            <div class="mosaic-overlay">
                <span class="mosaic-number">Post #{{ feynmanPosts.length - loop.index0 }}</span>
                <h3 class="mosaic-title">{{ post.data.title }}</h3>
                {% set cardDesc = post.data.excerpt or post.data.description %}
                {% if cardDesc %}
                <p class="mosaic-desc">{{ cardDesc | truncate(55) }}<span class="mosaic-more mosaic-more-feynman"> MORE</span></p>
                {% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
    {% if feynmanPosts.length > 12 %}
    <div class="mosaic-show-more">
        <button class="mosaic-load-btn" id="loadMoreCards">Show All {{ feynmanPosts.length }} Posts</button>
    </div>
    {% endif %}
</section>

{# === ARCHIVE LIST === #}
<section class="tier2-archive">
    <h2 class="tier2-archive-title">Archive</h2>
    <div class="tier2-archive-list">
        {% for post in feynmanPosts %}
        <div class="tier2-archive-item">
            <a href="{{ post.url }}">
                <span class="tier2-archive-num">#{{ feynmanPosts.length - loop.index0 }}</span>
                {{ post.data.title }}
            </a>
            <span class="tier2-archive-desc">{% if post.data.excerpt or post.data.description %}{{ (post.data.excerpt or post.data.description) | truncate(50) }}{% endif %}</span>
            {% if post.data.audio %}
            <span class="tier2-archive-play" data-audio="{{ post.data.audio }}">
                <button class="tier2-play-btn" aria-label="Play">&#9654;</button>
                <span class="tier2-duration">{% if post.data.audioLabel %}{{ post.data.audioLabel }}{% else %}0:00{% endif %}</span>
            </span>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</section>

<script>
(function() {
    var btn = document.getElementById('loadMoreCards');
    if (!btn) return;
    btn.addEventListener('click', function() {
        var hidden = document.querySelectorAll('.mosaic-card[data-lazy]');
        hidden.forEach(function(el) { el.style.display = ''; });
        btn.style.display = 'none';
    });
})();
</script>
<script defer src="/js/mosaic-player.js"></script>
<script>
(function() {
  var player = document.querySelector('.tier2-overview-player');
  if (!player) return;
  var btn = player.querySelector('.tier2-overview-play');
  var audio = player.querySelector('audio');
  if (!btn || !audio) return;
  audio.volume = 0.8;
  btn.addEventListener('click', function() {
    if (audio.paused) {
      audio.play();
      btn.innerHTML = '&#10074;&#10074;';
      btn.classList.add('playing');
      if ('mediaSession' in navigator) {
        navigator.mediaSession.metadata = new MediaMetadata({ title: 'Richard Feynman — Overview', artist: 'Cosmic Variety Show' });
      }
    } else {
      audio.pause();
      btn.innerHTML = '&#9654;';
      btn.classList.remove('playing');
    }
  });
  audio.addEventListener('ended', function() {
    btn.innerHTML = '&#9654;';
    btn.classList.remove('playing');
  });
})();
</script>
