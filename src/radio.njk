<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #0a0a0a; color: #eee; font-family: 'Inter', 'Helvetica Neue', sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; }
.radio-wrap { text-align: center; max-width: 500px; padding: 40px 20px; }
.radio-title { font-family: 'Playfair Display', serif; font-size: 1.6em; letter-spacing: 2px; margin-bottom: 5px; color: #fff; }
.radio-sub { color: #666; font-size: 0.85em; margin-bottom: 40px; }
.radio-now { color: #999; font-size: 0.9em; margin-bottom: 8px; min-height: 1.2em; }
.radio-track { color: #fff; font-size: 1.2em; font-weight: 600; margin-bottom: 25px; min-height: 1.5em; }
.radio-play-btn { width: 80px; height: 80px; border-radius: 50%; background: #222; border: 2px solid #444; color: #fff; font-size: 2em; cursor: pointer; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; transition: background 0.2s, border-color 0.2s; }
.radio-play-btn:hover { background: #333; border-color: #666; }
.radio-play-btn.playing { background: #1a3a1a; border-color: #27ae60; }
.radio-progress { width: 100%; height: 4px; background: #222; border-radius: 2px; margin-bottom: 8px; overflow: hidden; }
.radio-progress-bar { height: 100%; background: #555; width: 0; transition: width 0.5s linear; }
.radio-time { color: #555; font-size: 0.75em; margin-bottom: 30px; }
.radio-voice { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.7em; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; }
.voice-sagan { background: rgba(107, 163, 214, 0.2); color: #6ba3d6; border: 1px solid rgba(107, 163, 214, 0.3); }
.voice-feynman { background: rgba(255, 111, 0, 0.2); color: #ff6f00; border: 1px solid rgba(255, 111, 0, 0.3); }
.voice-fuller { background: rgba(212, 175, 55, 0.2); color: #D4AF37; border: 1px solid rgba(212, 175, 55, 0.3); }
.voice-chorus { background: rgba(255, 255, 255, 0.1); color: #fff; border: 1px solid rgba(255, 255, 255, 0.2); }
.radio-skip { background: none; border: 1px solid #333; color: #666; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-size: 0.8em; }
.radio-skip:hover { color: #aaa; border-color: #555; }
.radio-footer { color: #333; font-size: 0.7em; margin-top: 40px; }
</style>
</head>
<body>

<div class="radio-wrap">
  <div class="radio-title">COSMIC VARIETY SHOW</div>
  <div class="radio-sub">Three dead scientists. One dome. No commercials.</div>

  <div class="radio-voice" id="radio-voice"></div>
  <div class="radio-now" id="radio-now">Press play to start the radio</div>
  <div class="radio-track" id="radio-track"></div>

  <button class="radio-play-btn" id="radio-play" onclick="toggleRadio()">&#9654;</button>

  <div class="radio-progress"><div class="radio-progress-bar" id="radio-bar"></div></div>
  <div class="radio-time" id="radio-time"></div>

  <button class="radio-skip" onclick="skipTrack()">Skip &rarr;</button>

  <div class="radio-footer">cosmicvarietyshow.com/radio</div>
</div>

<script>
var playlist = [
  /* Station IDs */
  {src: "/audio/station-id-fuller.mp3", title: "Station ID", voice: "chorus", type: "id"},
  /* Candy Scripts */
  {src: "/audio/candy-feynman-ants.mp3", title: "The Ants", voice: "feynman", type: "candy"},
