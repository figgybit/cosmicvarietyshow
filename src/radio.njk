  {src: "/audio/candy-fuller-trim-tab.mp3", title: "The Trim Tab", voice: "fuller", type: "candy"},
  {src: "/audio/candy-fuller-ephemeralization.mp3", title: "Ephemeralization", voice: "fuller", type: "candy"},
  /* Commercials */
  {src: "/audio/commercial-spaceship-earth.mp3", title: "Ad: Spaceship Earth", voice: "fuller", type: "commercial"},
  {src: "/audio/commercial-geodesic-homes.mp3", title: "Ad: Geodesic Homes", voice: "fuller", type: "commercial"},
  {src: "/audio/commercial-world-game.mp3", title: "Ad: The World Game", voice: "fuller", type: "commercial"},
  /* Podcast Episodes */
  {src: "/audio/podcast-ep1-does-it-know.mp3", title: "Ep1: Does It Know What It Is Doing?", voice: "chorus", type: "podcast"},
  {src: "/audio/podcast-ep2-beauty-trap.mp3", title: "Ep2: The Beauty Trap", voice: "chorus", type: "podcast"},
  {src: "/audio/podcast-ep3-five-year-dawn.mp3", title: "Ep3: The Five-Year Dawn", voice: "chorus", type: "podcast"},
  {src: "/audio/podcast-ep4-mid-morning.mp3", title: "Ep4: Mid-Morning, 2036", voice: "chorus", type: "podcast"},
  /* V2 Post Clips — Feynman */
  {src: "/audio/v2-voice-feynman-ants-question.mp3", title: "You Are Not the Dominant Life Form", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-three-trillion-trees.mp3", title: "Three Trillion Trees", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-lenses-vs-facts.mp3", title: "Lenses vs Facts", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-ice-float.mp3", title: "Why Does Ice Float?", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-reality-made-of.mp3", title: "What Is Reality Made Of?", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-fragile-civilization.mp3", title: "How Fragile Is Civilization?", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-quantum-error-correction.mp3", title: "Hiding Secrets from the Universe", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-dark-matter.mp3", title: "The Invisible 85%", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-parallel-dimensions.mp3", title: "Every Path at Once", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-penrose.mp3", title: "Half Genius, Half Mystic", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-primes-quantum.mp3", title: "The Music Nobody Can Hear", voice: "feynman", type: "post"},
  {src: "/audio/v2-voice-feynman-the-gap.mp3", title: "The Gap Is the Same Shape", voice: "feynman", type: "post"},
  /* V2 Post Clips — Sagan */
  {src: "/audio/v2-voice-sagan-first-night.mp3", title: "The Night We Woke Up", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-shallow-right.mp3", title: "What Is Shallow Right?", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-poverty-question.mp3", title: "The Poverty Question", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-are-we-alone.mp3", title: "Are We Alone?", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-fragile-civilization.mp3", title: "How Fragile Is All This?", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-how-old-universe.mp3", title: "How Old Is the Universe?", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-jwst.mp3", title: "The Photograph I Begged For", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-exoplanets.mp3", title: "We Found Them — Almost", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-venus-warning.mp3", title: "Venus Was My Warning", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-dark-matter.mp3", title: "The Invisible Majority", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-noise-free-channel.mp3", title: "The Noise-Free Channel", voice: "sagan", type: "post"},
  {src: "/audio/v2-voice-sagan-epistemic-fold.mp3", title: "The Epistemic Fold Point", voice: "sagan", type: "post"},
  /* Convergence */
  {src: "/audio/v2-voice-feynman-which-cliff-first.mp3", title: "Which Cliff First?", voice: "chorus", type: "post"},
  {src: "/audio/v2-voice-feynman-futures-5-year.mp3", title: "2031: What Is Already On Its Way", voice: "chorus", type: "post"},
];

var audio = new Audio();
audio.volume = 0.8;
var playing = false;
var currentIdx = -1;
var shuffled = [];

function shuffle(arr) {
  var a = arr.slice();
  for (var i = a.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = a[i]; a[i] = a[j]; a[j] = t;
  }
  return a;
}

function buildPlaylist() {
  /* Shuffle content, but insert station ID every 4-5 tracks */
  var content = shuffle(playlist.filter(function(t) { return t.type !== 'id'; }));
  var ids = playlist.filter(function(t) { return t.type === 'id'; });
  var result = [];
  for (var i = 0; i < content.length; i++) {
    if (i % 4 === 0 && ids.length > 0) {
      result.push(ids[i % ids.length]);
    }
    result.push(content[i]);
  }
  return result;
}

function fmt(s) {
  var m = Math.floor(s / 60);
  var sec = Math.floor(s % 60);
  return m + ':' + (sec < 10 ? '0' : '') + sec;
}

function playTrack(idx) {
  if (idx >= shuffled.length) {
    shuffled = buildPlaylist();
    idx = 0;
  }
  currentIdx = idx;
  var track = shuffled[idx];
  audio.src = track.src;
  audio.play();

  document.getElementById('radio-now').textContent = track.type === 'id' ? '' : (track.type === 'commercial' ? 'SPONSORED BY THE COSMOS' : 'NOW PLAYING');
  document.getElementById('radio-track').textContent = track.title;

  var voiceEl = document.getElementById('radio-voice');
  voiceEl.textContent = track.voice === 'chorus' ? 'CHORUS' : track.voice.toUpperCase();
  voiceEl.className = 'radio-voice voice-' + track.voice;

  var btn = document.getElementById('radio-play');
  btn.innerHTML = '&#10074;&#10074;';
  btn.classList.add('playing');
  playing = true;

  if ('mediaSession' in navigator) {
    navigator.mediaSession.metadata = new MediaMetadata({
      title: track.title,
      artist: track.voice === 'chorus' ? 'Cosmic Variety Show' : track.voice.charAt(0).toUpperCase() + track.voice.slice(1),
      album: 'Cosmic Variety Show Radio'
    });
    navigator.mediaSession.setActionHandler('play', function() { audio.play(); });
    navigator.mediaSession.setActionHandler('pause', function() { audio.pause(); });
    navigator.mediaSession.setActionHandler('nexttrack', function() { skipTrack(); });
  }
}

function toggleRadio() {
  if (!playing) {
    if (currentIdx === -1) {
      shuffled = buildPlaylist();
      playTrack(0);
    } else {
      audio.play();
      document.getElementById('radio-play').innerHTML = '&#10074;&#10074;';
      document.getElementById('radio-play').classList.add('playing');
      playing = true;
    }
  } else {
    audio.pause();
    document.getElementById('radio-play').innerHTML = '&#9654;';
    document.getElementById('radio-play').classList.remove('playing');
    playing = false;
  }
}

function skipTrack() {
  playTrack(currentIdx + 1);
}

audio.addEventListener('ended', function() {
  playTrack(currentIdx + 1);
});

audio.addEventListener('timeupdate', function() {
  if (audio.duration) {
    var pct = (audio.currentTime / audio.duration) * 100;
    document.getElementById('radio-bar').style.width = pct + '%';
    document.getElementById('radio-time').textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
  }
});
</script>

</body>
</html>
