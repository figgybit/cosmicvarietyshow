<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TV — Cosmic Variety Show</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #0a0a0a; color: #eee; font-family: 'Inter', sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; overflow: hidden; }

/* CRT TV Frame */
.tv-cabinet { position: relative; background: linear-gradient(145deg, #3a2a1a, #2a1a0a, #1a0f05); border-radius: 30px; padding: 30px 30px 50px; box-shadow: 0 20px 60px rgba(0,0,0,0.8), inset 0 2px 4px rgba(255,255,255,0.05); max-width: 700px; width: 95vw; }
.tv-brand { text-align: center; font-size: 0.6em; color: #666; letter-spacing: 4px; text-transform: uppercase; margin-bottom: 10px; }
.tv-screen-bezel { background: #111; border-radius: 20px; padding: 8px; position: relative; overflow: hidden; }
.tv-screen { position: relative; width: 100%; aspect-ratio: 4/3; background: #000; border-radius: 14px; overflow: hidden; }

/* Scan lines */
.tv-screen::after { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.15) 2px, rgba(0,0,0,0.15) 4px); pointer-events: none; z-index: 5; border-radius: 14px; }

/* Screen curvature */
.tv-screen::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.4) 100%); pointer-events: none; z-index: 6; border-radius: 14px; }

/* Static */
.tv-static { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 4 4"><rect x="0" y="0" width="1" height="1" fill="rgba(255,255,255,0.03)"/><rect x="2" y="1" width="1" height="1" fill="rgba(255,255,255,0.05)"/><rect x="1" y="2" width="1" height="1" fill="rgba(255,255,255,0.02)"/><rect x="3" y="3" width="1" height="1" fill="rgba(255,255,255,0.04)"/></svg>'); z-index: 4; opacity: 0; transition: opacity 0.3s; border-radius: 14px; animation: staticFlicker 0.1s infinite; }
.tv-static.active { opacity: 1; }
@keyframes staticFlicker { 0% { opacity: 0.8; } 50% { opacity: 1; } 100% { opacity: 0.6; } }

/* Video container */
.tv-video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; }
.tv-video iframe, .tv-video video { width: 100%; height: 100%; border: none; }

/* Channel info overlay */
.tv-channel-info { position: absolute; top: 10px; right: 10px; z-index: 7; background: rgba(0,0,0,0.7); padding: 4px 10px; border-radius: 4px; font-size: 0.75em; color: #0f0; font-family: monospace; opacity: 0; transition: opacity 0.3s; }
.tv-channel-info.show { opacity: 1; }

/* Controls */
.tv-controls { display: flex; align-items: center; justify-content: space-between; margin-top: 15px; padding: 0 10px; }
.tv-channels { display: flex; gap: 8px; }
.tv-ch-btn { width: 40px; height: 40px; border-radius: 50%; background: #1a1a1a; border: 2px solid #333; color: #888; font-size: 0.7em; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.tv-ch-btn:hover { border-color: #666; color: #fff; }
.tv-ch-btn.active { background: #222; border-color: #0f0; color: #0f0; box-shadow: 0 0 8px rgba(0,255,0,0.2); }
.tv-skip { background: #1a1a1a; border: 1px solid #333; color: #666; padding: 6px 14px; border-radius: 4px; cursor: pointer; font-size: 0.75em; }
.tv-skip:hover { color: #fff; border-color: #666; }
.tv-power { width: 20px; height: 20px; border-radius: 50%; background: #333; border: none; cursor: pointer; box-shadow: 0 0 4px rgba(0,255,0,0.3); }
.tv-power.on { background: #0f0; box-shadow: 0 0 8px rgba(0,255,0,0.5); }

/* Channel labels */
.tv-channel-labels { display: flex; justify-content: center; gap: 15px; margin-top: 8px; font-size: 0.6em; color: #555; }
.tv-channel-labels span { cursor: pointer; }
.tv-channel-labels span:hover { color: #aaa; }

/* Now playing */
.tv-now-playing { text-align: center; margin-top: 12px; font-size: 0.7em; color: #444; min-height: 1.2em; }

@media (max-width: 600px) {
  .tv-cabinet { border-radius: 20px; padding: 15px 15px 35px; }
  .tv-ch-btn { width: 34px; height: 34px; font-size: 0.6em; }
}
</style>
</head>
<body>

<div class="tv-cabinet">
  <div class="tv-brand">Cosmic Variety Show</div>
  <div class="tv-screen-bezel">
    <div class="tv-screen" id="tv-screen">
      <div class="tv-static" id="tv-static"></div>
      <div class="tv-video" id="tv-video"></div>
      <div class="tv-channel-info" id="tv-ch-info">CH 1</div>
    </div>
  </div>
  <div class="tv-controls">
    <div class="tv-power on" id="tv-power" onclick="togglePower()"></div>
    <div class="tv-channels">
      <button class="tv-ch-btn active" onclick="switchChannel(1)">1</button>
      <button class="tv-ch-btn" onclick="switchChannel(2)">2</button>
      <button class="tv-ch-btn" onclick="switchChannel(3)">3</button>
      <button class="tv-ch-btn" onclick="switchChannel(4)">4</button>
      <button class="tv-ch-btn" onclick="switchChannel(5)">R</button>
    </div>
    <button class="tv-skip" onclick="skipVideo()">SKIP &rarr;</button>
  </div>
  <div class="tv-channel-labels">
    <span onclick="switchChannel(1)">THE DOME</span>
    <span onclick="switchChannel(2)">LECTURES</span>
    <span onclick="switchChannel(3)">COSMOS</span>
    <span onclick="switchChannel(4)">MUSIC</span>
    <span onclick="switchChannel(5)">RANDOM</span>
  </div>
  <div class="tv-now-playing" id="tv-now-playing"></div>
</div>

<script>
var channels = {
  1: { name: 'THE DOME', videos: [
    {type:'local', src:'/video/feynman-poem-what-they-did.mp4', title:'Feynman: What They Did While I Was Dead'},
    {type:'local', src:'/video/sagan-poem-what-the-cosmos-did.mp4', title:'Sagan: What the Cosmos Did While I Was Away'},
    {type:'local', src:'/video/fuller-poem-after-i-left.mp4', title:'Fuller: After I Left'},
  ]},
  2: { name: 'LECTURES', videos: [
    {type:'yt', id:'zMGXe7gXMHk', title:'Feynman: Fun to Imagine (Fire)'},
    {type:'yt', id:'MO0r930Sn_8', title:'Feynman: Fun to Imagine (Jiggling Atoms)'},
    {type:'yt', id:'kMSgE62S6oo', title:'Feynman: The Character of Physical Law 1'},
    {type:'yt', id:'2jLpDS8rjxE', title:'Feynman: Challenger O-Ring Demonstration'},
    {type:'yt', id:'Bgaw9qe7DEE', title:'Feynman: Take the World from Another Point of View'},
  ]},
  3: { name: 'COSMOS', videos: [
    {type:'yt', id:'wupToqz1e2g', title:'Pale Blue Dot — Carl Sagan'},
    {type:'yt', id:'GO5FwsblpT8', title:'A Glorious Dawn — Symphony of Science'},
    {type:'yt', id:'XH7ZRF6zNoc', title:'The Hubble Deep Field: The Most Important Image Ever Taken'},
    {type:'yt', id:'uD4izuDMUQA', title:'Cosmos: A Personal Voyage — Shores of the Cosmic Ocean'},
  ]},
  4: { name: 'MUSIC', videos: [
    {type:'yt', id:'HhwWAciO6F4', title:'Brian Eno — An Ending (Ascent)'},
    {type:'yt', id:'xjLMFSmA3IE', title:'Philip Glass — Metamorphosis'},
    {type:'yt', id:'S-Xm7s9eGxU', title:'Debussy — Clair de Lune'},
    {type:'yt', id:'kSE15tLBdso', title:'Bach — Cello Suite No. 1'},
    {type:'yt', id:'M0d4qM7gCH8', title:'Blind Willie Johnson — Dark Was the Night'},
  ]},
  5: { name: 'RANDOM', videos: [] }
};

var currentChannel = 1;
var currentIdx = 0;
var shuffled = [];
var powered = true;

function shuffle(arr) {
  var a = arr.slice();
  for (var i = a.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = a[i]; a[i] = a[j]; a[j] = t;
  }
  return a;
}

function buildRandom() {
  var all = [];
  for (var ch = 1; ch <= 4; ch++) {
    channels[ch].videos.forEach(function(v) { all.push(v); });
  }
  return shuffle(all);
}

function showStatic(duration, cb) {
  var s = document.getElementById('tv-static');
  s.classList.add('active');
  setTimeout(function() {
    s.classList.remove('active');
    if (cb) cb();
  }, duration || 400);
}

function showChannelInfo(ch) {
  var info = document.getElementById('tv-ch-info');
  info.textContent = 'CH ' + ch;
  info.classList.add('show');
  setTimeout(function() { info.classList.remove('show'); }, 2000);
}

function playVideo(video) {
  var container = document.getElementById('tv-video');
  var np = document.getElementById('tv-now-playing');
  container.innerHTML = '';
  np.textContent = video.title;

  if (video.type === 'yt') {
    var iframe = document.createElement('iframe');
    iframe.src = 'https://www.youtube.com/embed/' + video.id + '?autoplay=1&rel=0&modestbranding=1';
    iframe.setAttribute('allow', 'autoplay; encrypted-media');
    iframe.setAttribute('allowfullscreen', '');
    container.appendChild(iframe);
  } else {
    var vid = document.createElement('video');
    vid.src = video.src;
    vid.autoplay = true;
    vid.controls = false;
    vid.playsInline = true;
    vid.volume = 0.8;
    vid.addEventListener('ended', function() { skipVideo(); });
    container.appendChild(vid);
  }
}

function switchChannel(ch) {
  if (!powered) return;
  currentChannel = ch;
  currentIdx = 0;

  document.querySelectorAll('.tv-ch-btn').forEach(function(b, i) {
    b.classList.toggle('active', i + 1 === ch);
  });

  if (ch === 5) {
    shuffled = buildRandom();
  } else {
    shuffled = shuffle(channels[ch].videos);
  }

  showStatic(400, function() {
    showChannelInfo(ch);
    if (shuffled.length > 0) {
      playVideo(shuffled[0]);
    }
  });
}

function skipVideo() {
  if (!powered) return;
  currentIdx++;
  if (currentIdx >= shuffled.length) {
    if (currentChannel === 5) {
      shuffled = buildRandom();
    } else {
      shuffled = shuffle(channels[currentChannel].videos);
    }
    currentIdx = 0;
  }
  showStatic(300, function() {
    playVideo(shuffled[currentIdx]);
  });
}

function togglePower() {
  powered = !powered;
  var pwr = document.getElementById('tv-power');
  var container = document.getElementById('tv-video');
  var np = document.getElementById('tv-now-playing');
  if (powered) {
    pwr.classList.add('on');
    switchChannel(currentChannel);
  } else {
    pwr.classList.remove('on');
    container.innerHTML = '';
    np.textContent = '';
    showStatic(200);
  }
}

/* Auto-start channel 1 */
switchChannel(1);
</script>

</body>
</html>
