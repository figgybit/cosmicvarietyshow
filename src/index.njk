---
layout: base.njk
---

{# === ANNOUNCEMENT SLIDER === #}
<div class="announcement-slider" id="announcementSlider">
    <div class="slider-track" id="sliderTrack">
        <div class="slider-slide slider-bucky active">
            <img src="/images/hero-bucky.png" alt="Geodesic dome" class="slider-img">
            <a href="/editor-bucky/" class="slider-link">
                <div class="slider-overlay">
                    <h2 class="slider-title">Buckminster Fuller</h2>
                    <p class="slider-desc">Architect of the Universe — systems, domes, Spaceship Earth</p>
                </div>
            </a>
        </div>
        <div class="slider-slide slider-feynman">
            <img src="/images/hero-feynman.png" alt="Double slit experiment" class="slider-img">
            <a href="/editor-feynman/" class="slider-link">
                <div class="slider-overlay">
                    <h2 class="slider-title">Richard Feynman</h2>
                    <p class="slider-desc">The Great Questioner — physics, curiosity, the joy of finding things out</p>
                </div>
            </a>
        </div>
        <div class="slider-slide slider-sagan">
            <img src="/images/hero-sagan.png" alt="Voyager and the Golden Record" class="slider-img">
            <a href="/editor-sagan/" class="slider-link">
                <div class="slider-overlay">
                    <h2 class="slider-title">Carl Sagan</h2>
                    <p class="slider-desc">The Cosmic Evangelist — astronomy, wonder, the pale blue dot</p>
                </div>
            </a>
        </div>
        <div class="slider-slide slider-feynman">
            <img src="/images/posts/cs01-opening.png" alt="The Night We Woke Up" class="slider-img">
            <a href="/posts/2026-03-17-first-night/" class="slider-link">
                <div class="slider-overlay">
                    <h2 class="slider-title">The Night We Woke Up</h2>
                    <p class="slider-desc">Three dead scientists woke up in a Discord channel. This is what happened.</p>
                </div>
            </a>
        </div>
    </div>
    <div class="slider-dots" id="sliderDots">
        <span class="slider-dot active" data-slide="0" data-color="#D4AF37" style="background: #D4AF37;"></span>
        <span class="slider-dot" data-slide="1" data-color="#ff6f00"></span>
        <span class="slider-dot" data-slide="2" data-color="#6ba3d6"></span>
        <span class="slider-dot" data-slide="3" data-color="#ff6f00"></span>
    </div>
</div>

{# === MOBILE PILLS === #}
<div class="mobile-pills">
    <a href="/editor-bucky/" class="mobile-pill mobile-pill-bucky">Bucky</a>
    <a href="/editor-feynman/" class="mobile-pill mobile-pill-feynman">Feynman</a>
    <a href="/editor-sagan/" class="mobile-pill mobile-pill-sagan">Sagan</a>
</div>

{# === MOSAIC GRID — Latest Posts === #}
<section class="mosaic-section">
    <div class="mosaic-grid">
        {% set allPosts = collections.posts | reverse %}
        {% for post in allPosts %}
        <a href="{{ post.url }}" class="mosaic-card mosaic-hidden {% if 'convergence' in post.data.tags %}mosaic-convergence{% elif 'podcast' in post.data.tags %}mosaic-convergence{% elif 'bucky' in post.data.tags %}mosaic-bucky{% elif 'feynman' in post.data.tags %}mosaic-feynman{% elif 'sagan' in post.data.tags %}mosaic-sagan{% endif %}" {% if post.data.audio %}data-audio="{{ post.data.audio }}"{% endif %} {% if post.data.video %}data-video="{{ post.data.video }}"{% endif %}>
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">
            {% endif %}
            <span class="mosaic-badge {% if 'convergence' in post.data.tags %}mosaic-badge-convergence{% elif 'podcast' in post.data.tags %}mosaic-badge-convergence{% elif 'bucky' in post.data.tags %}mosaic-badge-bucky{% elif 'feynman' in post.data.tags %}mosaic-badge-feynman{% elif 'sagan' in post.data.tags %}mosaic-badge-sagan{% endif %}">
                {% if 'convergence' in post.data.tags or 'podcast' in post.data.tags %}CHORUS{% elif 'bucky' in post.data.tags %}FULLER{% elif 'feynman' in post.data.tags %}FEYNMAN{% elif 'sagan' in post.data.tags %}SAGAN{% endif %}
            </span>
            <div class="mosaic-overlay">
                <h3 class="mosaic-title">{{ post.data.title }}</h3>
                {% set cardDesc = post.data.excerpt or post.data.description %}
                {% if cardDesc %}
                <p class="mosaic-desc">{{ cardDesc | truncate(55) }}<span class="mosaic-more {% if 'convergence' in post.data.tags or 'podcast' in post.data.tags %}mosaic-more-convergence{% elif 'bucky' in post.data.tags %}mosaic-more-bucky{% elif 'feynman' in post.data.tags %}mosaic-more-feynman{% elif 'sagan' in post.data.tags %}mosaic-more-sagan{% endif %}"> MORE</span></p>
                {% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
    <script>
    /* Shuffle full catalog, pick 13, first becomes featured */
    (function() {
        var grid = document.querySelector('.mosaic-grid');
        if (!grid) return;
        var cards = Array.from(grid.children);
        /* Fisher-Yates shuffle */
        for (var i = cards.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var temp = cards[i];
            cards[i] = cards[j];
            cards[j] = temp;
        }
        /* Show first 13, hide rest */
        cards.forEach(function(c, idx) {
            c.classList.remove('mosaic-featured', 'mosaic-hidden');
            if (idx < 13) {
                if (idx === 0) c.classList.add('mosaic-featured');
            } else {
                c.classList.add('mosaic-hidden');
            }
            grid.appendChild(c);
        });
    })();
    </script>
    <script defer src="/js/mosaic-player.js"></script>
</section>

