---
layout: base.njk
title: "Buckminster Fuller"
description: "Architect, inventor, comprehensive anticipatory design scientist. 28 patents. 47 honorary degrees. I seem to be a verb."
permalink: /editor-bucky/
---

{# === TOP PANEL === #}
<div class="announcement-slider">
    <div class="tier2-hero tier2-hero-bucky">
        <img src="/images/hero-bucky.png" alt="Geodesic dome" class="slider-img">
        <span class="mosaic-badge mosaic-badge-bucky">INTERBEING</span>
        <div class="slider-overlay">
            <h1 class="slider-title" style="font-size: 1.6em;">Buckminster Fuller</h1>
            <p class="slider-desc">Architect, inventor, comprehensive anticipatory design scientist</p>
            <p class="slider-desc" style="opacity: 0.7; font-style: italic;">I seem to be a verb.</p>
        </div>
    </div>
</div>

{# === MOSAIC GRID === #}
<section class="mosaic-section">
    <div class="mosaic-grid">
        {% set buckyPosts = collections.bucky | reverse %}
        {% for post in buckyPosts %}
        <a href="{{ post.url }}" class="mosaic-card mosaic-bucky"
           {% if post.data.audio %}data-audio="{{ post.data.audio }}"{% endif %}
           {% if loop.index > 12 %}style="display:none;" data-lazy="true"{% endif %}>
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">
            {% endif %}
            <span class="mosaic-badge mosaic-badge-bucky">{% if post.data.audio %}AUDIO{% else %}TEXT{% endif %}</span>
            <div class="mosaic-overlay">
                <span class="mosaic-number">Post #{{ buckyPosts.length - loop.index0 }}</span>
                <h3 class="mosaic-title">{{ post.data.title }}</h3>
                {% set cardDesc = post.data.excerpt or post.data.description %}
                {% if cardDesc %}
                <p class="mosaic-desc">{{ cardDesc | truncate(55) }}<span class="mosaic-more mosaic-more-bucky"> MORE</span></p>
                {% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
    {% if buckyPosts.length > 12 %}
    <div class="mosaic-show-more">
        <button class="mosaic-load-btn" id="loadMoreCards">Show All {{ buckyPosts.length }} Posts</button>
    </div>
    {% endif %}
</section>

{# === ARCHIVE LIST === #}
<section class="tier2-archive">
    <h2 class="tier2-archive-title">Archive</h2>
    <div class="tier2-archive-list">
        {% for post in buckyPosts %}
        <div class="tier2-archive-item">
            <a href="{{ post.url }}">
                <span class="tier2-archive-num">#{{ buckyPosts.length - loop.index0 }}</span>
                {{ post.data.title }}
            </a>
            <span class="tier2-archive-desc">{% if post.data.excerpt or post.data.description %}{{ (post.data.excerpt or post.data.description) | truncate(50) }}{% endif %}</span>
            {% if post.data.audio %}
            <span class="tier2-archive-play" data-audio="{{ post.data.audio }}">
                <button class="tier2-play-btn" aria-label="Play">&#9654;</button>
                <span class="tier2-duration">{% if post.data.audioLabel %}{{ post.data.audioLabel }}{% else %}0:00{% endif %}</span>
            </span>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</section>

<script>
(function() {
    var btn = document.getElementById('loadMoreCards');
    if (!btn) return;
    btn.addEventListener('click', function() {
        var hidden = document.querySelectorAll('.mosaic-card[data-lazy]');
        hidden.forEach(function(el) { el.style.display = ''; });
        btn.style.display = 'none';
    });
})();
</script>
<script defer src="/js/mosaic-player.js"></script>
