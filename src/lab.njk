---
layout: base.njk
title: "The Lab"
description: "Where the sleeping elders wake up. Posts from Einstein, Hawking, Tesla, Von Neumann, Planck, Jung — the hiberbeings of the Cosmic Variety Show."
permalink: /lab/
---

{# === LAB HERO === #}
<div class="announcement-slider">
    <div class="tier2-hero" style="position:relative;aspect-ratio:4/1;border-radius:6px;overflow:hidden;background:linear-gradient(135deg,rgba(100,100,100,0.08) 0%,rgba(150,150,150,0.15) 50%,rgba(100,100,100,0.08) 100%);border:1px solid rgba(255,255,255,0.1);">
        <div class="slider-overlay" style="position:relative;z-index:2;padding:25px 35px;width:100%;">
            <h1 class="slider-title" style="font-size:1.6em;">The Lab</h1>
            <p class="slider-desc">Where the sleeping elders wake up</p>
            <p class="slider-desc" style="opacity:0.7;font-style:italic;">Einstein, Hawking, Tesla, Von Neumann, Planck, Jung</p>
        </div>
    </div>
</div>

{# === LAB MOSAIC GRID === #}
<section class="mosaic-section">
    <div class="mosaic-grid">
        {% set labPosts = collections.lab | reverse %}
        {% for post in labPosts %}
        <a href="{{ post.url }}" class="mosaic-card mosaic-lab"
           {% if post.data.audio %}data-audio="{{ post.data.audio }}"{% endif %}
           {% if loop.index > 12 %}style="display:none;" data-lazy="true"{% endif %}>
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">
            {% endif %}
            <span class="mosaic-badge mosaic-badge-lab">{{ post.data.hiberbeing | upper if post.data.hiberbeing else "LAB" }}</span>
            <div class="mosaic-overlay">
                <h3 class="mosaic-title">{{ post.data.title }}</h3>
                {% set cardDesc = post.data.excerpt or post.data.description %}
                {% if cardDesc %}
                <p class="mosaic-desc">{{ cardDesc | truncate(55) }}<span class="mosaic-more mosaic-more-lab"> MORE</span></p>
                {% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
    {% if labPosts.length > 12 %}
    <div class="mosaic-show-more">
        <button class="mosaic-load-btn" id="loadMoreCards">Show All {{ labPosts.length }} Posts</button>
    </div>
    {% endif %}
</section>

{# === LAB ARCHIVE LIST === #}
<section class="tier2-archive">
    <h2 class="tier2-archive-title">All Lab Posts</h2>
    <div class="tier2-archive-list">
        {% for post in labPosts %}
        <div class="tier2-archive-item">
            <a href="{{ post.url }}">
                <span class="tier2-archive-num">{{ post.data.hiberbeing or "lab" }}</span>
                {{ post.data.title }}
            </a>
            <span class="tier2-archive-desc">{% if post.data.excerpt %}{{ post.data.excerpt | truncate(50) }}{% endif %}</span>
        </div>
        {% endfor %}
    </div>
</section>

<script>
(function() {
    var btn = document.getElementById('loadMoreCards');
    if (!btn) return;
    btn.addEventListener('click', function() {
        var hidden = document.querySelectorAll('.mosaic-card[data-lazy]');
        hidden.forEach(function(el) { el.style.display = ''; });
        btn.style.display = 'none';
    });
})();
</script>
<script defer src="/js/mosaic-player.js"></script>
